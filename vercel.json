{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/leads",
      "dest": "/api/leads.js"
    },
    {
      "src": "/api/auth-config",
      "dest": "/api/auth-config.js"
    },
    {
      "src": "/api/me",
      "dest": "/api/me.js"
    },
    {
      "src": "/api/users",
      "dest": "/api/users.js"
    },
    {
      "src": "/api/site-content",
      "dest": "/api/site-content.js"
    },
    {
      "src": "/api/site-media",
      "dest": "/api/site-content.js"
    },
    {
      "src": "/api/public-site-content",
      "dest": "/api/public-site-content.js"
    },
    {
      "src": "/api/clients",
      "dest": "/api/clients.js"
    },
    {
      "src": "/api/client-drive",
      "dest": "/api/clients.js"
    },
    {
      "src": "/api/ped",
      "dest": "/api/app.js"
    },
    {
      "src": "/api/ped-carousel-download",
      "dest": "/api/app.js"
    },
    {
      "src": "/api/ped-share",
      "dest": "/api/app.js"
    },
    {
      "src": "/api/public-ped",
      "dest": "/api/app.js"
    },
    {
      "src": "/api/clients/sync-clickup",
      "dest": "/api/clients-sync-clickup.js"
    },
    {
      "src": "/api/clickup/team",
      "dest": "/api/clickup-team.js"
    },
    {
      "src": "/api/clickup/tasks",
      "dest": "/api/clickup-tasks.js"
    },
    {
      "src": "/api/smart-working",
      "dest": "/api/app.js"
    },
    {
      "src": "/api/clickup/webhook",
      "dest": "/api/clickup-tasks.js"
    },
    {
      "src": "/api/ai/task-assist",
      "dest": "/api/clickup-tasks.js"
    },
    {
      "src": "/",
      "dest": "/api/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/app.js"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://bemarketinggroup-del.github.io"
        }
      ]
    }
  ]
}
