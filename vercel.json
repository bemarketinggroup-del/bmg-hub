{
  "cleanUrls": true,
  "buildCommand": "node --check app.js && node --check api/leads.js && node --check api/site-content.js",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://bemarketinggroup-del.github.io"
        }
      ]
    }
  ]
}
